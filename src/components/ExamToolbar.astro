---
const { editHref, showTocToggle = false } = Astro.props;
---

<div
  class="floating-toolbar"
  id="examToolbar"
  data-expanded="false"
>
  <div
    class="floating-toolbar-actions"
    id="examToolbarActions"
  >
    <button
      class="floating-toolbar-control cursor-pointer transition-opacity active:scale-95"
      id="backToTop"
      type="button"
      aria-label="回到顶部"
      data-tooltip="回到顶部"
      data-toolbar-action
    >
      <svg aria-hidden="true" class="h-5 w-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2">
        <path d="M18 15l-6-6-6 6"></path>
      </svg>
    </button>
    {
      showTocToggle && (
        <button
          class="floating-toolbar-control exam-toolbar-toc-toggle cursor-pointer active:scale-95"
          id="examTocMobileToggle"
          type="button"
          aria-label="显示目录"
          aria-expanded="false"
          data-tooltip="目录"
          data-toolbar-action
        >
          <svg
            aria-hidden="true"
            class="h-5 w-5"
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
          >
            <path d="M9 6h10"></path>
            <path d="M9 12h10"></path>
            <path d="M9 18h10"></path>
            <circle cx="5" cy="6" r="1" fill="currentColor" stroke="none"></circle>
            <circle cx="5" cy="12" r="1" fill="currentColor" stroke="none"></circle>
            <circle cx="5" cy="18" r="1" fill="currentColor" stroke="none"></circle>
          </svg>
        </button>
      )
    }
    {
      editHref && (
        <a
          class="no-underline floating-toolbar-control active:scale-95"
          href={editHref}
          aria-label="在 GitHub 上编辑"
          data-tooltip="在 GitHub 上编辑"
          data-toolbar-action
        >
          <svg aria-hidden="true" class="h-5 w-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2">
            <path d="M12 20h9"></path>
            <path d="m16.5 3.5 4 4L8 20l-5 1 1-5 12.5-12.5Z"></path>
          </svg>
        </a>
      )
    }
    <button
      class="floating-toolbar-control cursor-pointer active:scale-95"
      id="examPrint"
      type="button"
      aria-label="打印试卷"
      data-tooltip="打印试卷"
      data-toolbar-action
    >
      <svg aria-hidden="true" class="h-5 w-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8">
        <polyline points="6 9 6 2 18 2 18 9"></polyline>
        <path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"></path>
        <rect x="6" y="14" width="12" height="8"></rect>
      </svg>
    </button>
    <button
      class="floating-toolbar-control cursor-pointer active:scale-95 disabled:cursor-default disabled:opacity-50"
      id="examAnswersToggle"
      type="button"
      aria-label="显示全部答案"
      aria-pressed="false"
      data-tooltip="显示全部答案"
      data-toolbar-action
    >
      <svg aria-hidden="true" class="h-5 w-5" data-exam-toggle-icon="show" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8">
        <path d="M2 12s3.6-6 10-6 10 6 10 6-3.6 6-10 6-10-6-10-6Z"></path>
        <circle cx="12" cy="12" r="3"></circle>
      </svg>
      <svg aria-hidden="true" class="h-5 w-5" data-exam-toggle-icon="hide" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8">
        <path d="M3 3l18 18"></path>
        <path d="M10.6 10.7a2 2 0 0 0 2.7 2.7"></path>
        <path d="M9.4 5.6A10.7 10.7 0 0 1 12 5.2c6.4 0 10 6 10 6a17.7 17.7 0 0 1-4.1 4.6"></path>
        <path d="M6.2 6.3C3.7 8 2 10.8 2 10.8s3.6 6 10 6c1.2 0 2.4-.2 3.4-.6"></path>
      </svg>
    </button>
  </div>
  <button
    class="floating-toolbar-control floating-toolbar-toggle cursor-pointer active:scale-95"
    id="examToolbarToggle"
    type="button"
    aria-label="展开工具栏"
    aria-expanded="false"
    aria-controls="examToolbarActions"
    data-tooltip="展开工具栏"
  >
    <svg
      aria-hidden="true"
      class="h-5 w-5"
      data-toolbar-toggle-icon="open"
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-linecap="round"
      stroke-linejoin="round"
      stroke-width="2"
    >
      <path d="M12 5v14"></path>
      <path d="M5 12h14"></path>
    </svg>
    <svg
      aria-hidden="true"
      class="h-5 w-5"
      data-toolbar-toggle-icon="close"
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-linecap="round"
      stroke-linejoin="round"
      stroke-width="2"
    >
      <path d="m18 6-12 12"></path>
      <path d="M6 6l12 12"></path>
    </svg>
  </button>
</div>

<dialog
  id="examPrintDialog"
  class="exam-print-dialog"
  aria-labelledby="examPrintDialogTitle"
>
  <div class="exam-print-dialog-panel">
    <h2 id="examPrintDialogTitle" class="exam-print-dialog-title">打印选项</h2>
    <p class="exam-print-dialog-desc">选择要包含在打印稿中的内容。</p>
    <label class="exam-print-dialog-option">
      <input
        id="examPrintInfo"
        type="checkbox"
        checked
      />
      <span>打印试题概要信息</span>
    </label>
    <label class="exam-print-dialog-option exam-print-dialog-option-spaced">
      <input
        id="examPrintAnswers"
        type="checkbox"
        checked
      />
      <span>打印答案</span>
    </label>
    <div class="exam-print-dialog-actions">
      <button
        id="examPrintDialogCancel"
        class="exam-print-dialog-btn exam-print-dialog-btn-secondary"
        type="button"
      >
        取消
      </button>
      <button
        id="examPrintDialogConfirm"
        class="exam-print-dialog-btn exam-print-dialog-btn-primary"
        type="button"
      >
        打印
      </button>
    </div>
  </div>
</dialog>

<style is:global>
  #examAnswersToggle [data-exam-toggle-icon] {
    display: none;
  }
  #examAnswersToggle[data-state="hidden"] [data-exam-toggle-icon="show"] {
    display: block;
  }
  #examAnswersToggle[data-state="shown"] [data-exam-toggle-icon="hide"] {
    display: block;
  }
  #backToTop {
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.2s ease;
  }
  #backToTop.is-visible {
    opacity: 1;
    pointer-events: auto;
  }
  .exam-print-dialog {
    background: none;
    border: none;
    margin: auto;
    max-width: calc(100vw - 2rem);
    padding: 0;
    width: 24rem;
  }
  .exam-print-dialog::backdrop {
    background: rgb(15 23 42 / 45%);
    backdrop-filter: blur(2px);
  }
  .exam-print-dialog-panel {
    border: 1px solid rgb(226 232 240);
    border-radius: 12px;
    background: #fff;
    box-shadow:
      0 10px 15px -3px rgb(15 23 42 / 12%),
      0 4px 6px -4px rgb(15 23 42 / 10%);
    color: rgb(15 23 42);
    padding: 1.25rem;
  }
  .dark .exam-print-dialog-panel {
    background: rgb(15 23 42);
    border-color: rgb(30 41 59);
    color: rgb(241 245 249);
  }
  .exam-print-dialog-title {
    font-size: 1.05rem;
    font-weight: 600;
    margin: 0;
  }
  .exam-print-dialog-desc {
    color: rgb(100 116 139);
    font-size: 0.875rem;
    margin: 0.4rem 0 1rem;
  }
  .dark .exam-print-dialog-desc {
    color: rgb(148 163 184);
  }
  .exam-print-dialog-option {
    align-items: center;
    border: 1px solid rgb(226 232 240);
    border-radius: 10px;
    cursor: pointer;
    display: flex;
    gap: 0.65rem;
    font-size: 0.95rem;
    padding: 0.75rem 0.85rem;
    user-select: none;
  }
  .exam-print-dialog-option-spaced {
    margin-top: 0.75rem;
  }
  .dark .exam-print-dialog-option {
    border-color: rgb(51 65 85);
  }
  .exam-print-dialog-option input {
    accent-color: rgb(15 23 42);
    height: 1rem;
    margin: 0;
    width: 1rem;
  }
  .dark .exam-print-dialog-option input {
    accent-color: rgb(226 232 240);
  }
  .exam-print-dialog-actions {
    display: flex;
    gap: 0.6rem;
    justify-content: flex-end;
    margin-top: 1.15rem;
  }
  .exam-print-dialog-btn {
    border: 1px solid transparent;
    border-radius: 8px;
    cursor: pointer;
    font-size: 0.9rem;
    font-weight: 500;
    padding: 0.5rem 0.95rem;
  }
  .exam-print-dialog-btn-secondary {
    background: transparent;
    border-color: rgb(226 232 240);
    color: rgb(51 65 85);
  }
  .dark .exam-print-dialog-btn-secondary {
    border-color: rgb(51 65 85);
    color: rgb(203 213 225);
  }
  .exam-print-dialog-btn-secondary:hover {
    background: rgb(248 250 252);
  }
  .dark .exam-print-dialog-btn-secondary:hover {
    background: rgb(30 41 59);
  }
  .exam-print-dialog-btn-primary {
    background: rgb(15 23 42);
    color: #fff;
  }
  .dark .exam-print-dialog-btn-primary {
    background: rgb(226 232 240);
    color: rgb(15 23 42);
  }
  .exam-print-dialog-btn-primary:hover {
    opacity: 0.92;
  }
  @media print {
    @page {
      margin: 2cm 1.5cm;
    }
    #examToolbar,
    #examPrintDialog {
      display: none !important;
    }
    nav, footer {
      display: none !important;
    }
    html[data-print-info="false"] #examInfoBox,
    html[data-print-info="false"] .exam-info-box {
      display: none !important;
    }
    .exam-blank {
      background: transparent !important;
      min-width: 0 !important;
    }
    .exam-blank-placeholder {
      display: none !important;
    }
    .exam-blank[aria-pressed="true"].exam-blank,
    .exam-blank[aria-pressed="false"].exam-blank {
      background: transparent !important;
      box-shadow: 0 1px 0 0 #999 !important;
      border-radius: 0 !important;
    }
    .exam-choices-submit {
      display: none !important;
    }
    .exam-choice-option {
      border-color: transparent !important;
      box-shadow: none !important;
      padding: 0.2em 0.5em !important;
    }
    .print-footer {
      display: block !important;
      margin-top: 2em;
      padding-top: 1em;
      border-top: 1px solid #ccc;
      font-size: 0.85em;
      color: #666;
      line-height: 1.8;
    }
    .print-footer a {
      color: #444;
    }
    html[data-print-answers="true"] .exam-blank-answer {
      visibility: visible !important;
    }
    html[data-print-answers="true"] .exam-solution {
      break-inside: avoid;
      border-radius: 12px !important;
      border: 1.5px solid #ccc !important;
    }
    html[data-print-answers="true"] .exam-solution[open],
    html[data-print-answers="true"] .exam-solution:not([open]) {
      overflow: visible !important;
    }
    html[data-print-answers="true"] .exam-solution-summary {
      display: none !important;
    }
    html[data-print-answers="true"] .exam-solution-content {
      display: block !important;
      padding: 1em 1.2em !important;
    }
    html[data-print-answers="true"] .exam-choices .exam-choice-option[data-answer="true"] {
      outline: 1px solid #000 !important;
      outline-offset: -2px;
      border-radius: 8px !important;
    }
    html[data-print-answers="true"] .exam-choices .exam-choice-option.is-correct .exam-choice-indicator,
    html[data-print-answers="true"] .exam-choices .exam-choice-option[data-answer="true"] .exam-choice-indicator {
      border-color: #000 !important;
      border-width: 2px !important;
    }
    html[data-print-answers="true"] .exam-choices .exam-choice-option.is-correct .exam-choice-indicator::after,
    html[data-print-answers="true"] .exam-choices .exam-choice-option[data-answer="true"] .exam-choice-indicator::after {
      background: #000 !important;
      content: "" !important;
      inset: 1.5px !important;
      position: absolute !important;
    }
    html[data-print-answers="true"] .exam-choices.single .exam-choice-option[data-answer="true"] .exam-choice-indicator::after {
      border-radius: 50% !important;
    }

    html[data-print-answers="false"] .exam-blank-answer {
      visibility: hidden !important;
    }
    html[data-print-answers="false"] .exam-solution {
      display: none !important;
    }
    html[data-print-answers="false"] .exam-choices .exam-choice-option.is-correct,
    html[data-print-answers="false"] .exam-choices .exam-choice-option.is-wrong,
    html[data-print-answers="false"] .exam-choices .exam-choice-option.is-missed {
      background: transparent !important;
      border-color: transparent !important;
    }
    html[data-print-answers="false"] .exam-choices .exam-choice-option.is-correct .exam-choice-indicator,
    html[data-print-answers="false"] .exam-choices .exam-choice-option.is-wrong .exam-choice-indicator,
    html[data-print-answers="false"] .exam-choices .exam-choice-option.is-missed .exam-choice-indicator,
    html[data-print-answers="false"] .exam-choices .exam-choice-input:checked + .exam-choice-indicator,
    html[data-print-answers="false"] .exam-choices .exam-choice-option[data-answer="true"] .exam-choice-indicator {
      border-color: #9ca3af !important;
      border-width: 1.5px !important;
    }
    html[data-print-answers="false"] .exam-choices .exam-choice-option.is-correct .exam-choice-indicator::after,
    html[data-print-answers="false"] .exam-choices .exam-choice-option.is-wrong .exam-choice-indicator::after,
    html[data-print-answers="false"] .exam-choices .exam-choice-option.is-missed .exam-choice-indicator::after,
    html[data-print-answers="false"] .exam-choices .exam-choice-input:checked + .exam-choice-indicator::after,
    html[data-print-answers="false"] .exam-choices .exam-choice-option[data-answer="true"] .exam-choice-indicator::after {
      content: none !important;
    }
  }
</style>

<script is:inline>
  var examToolbar = document.getElementById("examToolbar");
  var examToolbarToggle = document.getElementById("examToolbarToggle");
  var examAnswersToggle = document.getElementById("examAnswersToggle");
  var backToTop = document.getElementById("backToTop");
  var examPrint = document.getElementById("examPrint");
  var setExamToolbarExpanded = function(expanded) {
    if (!(examToolbar instanceof HTMLElement)) return;
    examToolbar.dataset.expanded = expanded ? "true" : "false";
    if (examToolbarToggle instanceof HTMLButtonElement) {
      examToolbarToggle.setAttribute("aria-expanded", String(expanded));
      examToolbarToggle.setAttribute(
        "aria-label",
        expanded ? "收起工具栏" : "展开工具栏",
      );
      examToolbarToggle.dataset.tooltip = expanded ? "收起工具栏" : "展开工具栏";
    }
  };
  var toggleExamToolbarExpanded = function() {
    setExamToolbarExpanded(examToolbar?.dataset.expanded !== "true");
  };

  setExamToolbarExpanded(false);
  examToolbarToggle?.addEventListener("click", function(event) {
    event.stopPropagation();
    toggleExamToolbarExpanded();
  });
  examToolbar?.querySelectorAll("[data-toolbar-action]").forEach(function(control) {
    control.addEventListener("click", function() {
      setExamToolbarExpanded(false);
    });
  });
  document.addEventListener("click", function(event) {
    if (!(examToolbar instanceof HTMLElement) || examToolbar.dataset.expanded !== "true")
      return;
    if (examToolbar.contains(event.target))
      return;
    setExamToolbarExpanded(false);
  });
  document.addEventListener("keydown", function(event) {
    if (event.key === "Escape")
      setExamToolbarExpanded(false);
  });

  // Back to top
  var updateBackToTopVisibility = function() {
    if (!backToTop) return;
    backToTop.classList.toggle("is-visible", window.scrollY > 200);
  };
  updateBackToTopVisibility();
  window.addEventListener("scroll", updateBackToTopVisibility, { passive: true });
  backToTop?.addEventListener("click", function() {
    window.scrollTo({ top: 0, behavior: "smooth" });
  });

  // Print options dialog
  var examPrintDialog = document.getElementById("examPrintDialog");
  var examPrintAnswers = document.getElementById("examPrintAnswers");
  var examPrintInfo = document.getElementById("examPrintInfo");
  var examPrintDialogCancel = document.getElementById("examPrintDialogCancel");
  var examPrintDialogConfirm = document.getElementById("examPrintDialogConfirm");
  var printUrlFooter = null;
  var prePrintState = null;
  var printWithAnswers = true;
  var printWithInfo = true;

  var openExamPrintDialog = function() {
    if (!(examPrintDialog instanceof HTMLDialogElement)) {
      window.print();
      return;
    }
    if (examPrintAnswers instanceof HTMLInputElement) {
      examPrintAnswers.checked = printWithAnswers;
    }
    if (examPrintInfo instanceof HTMLInputElement) {
      examPrintInfo.checked = printWithInfo;
    }
    if (!examPrintDialog.open) examPrintDialog.showModal();
  };

  var closeExamPrintDialog = function() {
    if (examPrintDialog instanceof HTMLDialogElement && examPrintDialog.open) {
      examPrintDialog.close();
    }
  };

  var startExamPrint = function(withAnswers, withInfo) {
    printWithAnswers = withAnswers;
    printWithInfo = withInfo;
    document.documentElement.dataset.printAnswers = withAnswers ? "true" : "false";
    document.documentElement.dataset.printInfo = withInfo ? "true" : "false";
    closeExamPrintDialog();
    window.print();
  };

  // Print preparation (works for button flow and browser print)
  window.addEventListener("beforeprint", function() {
    var withAnswers = document.documentElement.dataset.printAnswers !== "false";
    printWithAnswers = withAnswers;
    // Save current state to restore after print
    prePrintState = {
      blanks: [],
      solutions: [],
      choices: [],
      withAnswers: withAnswers,
    };

    if (withAnswers) {
      // Reveal all answers inline
      if (!window.__examState?.getAllShown?.()) {
        window.__examState?.toggleAll?.();
        prePrintState.wasHidden = true;
      }
      // Open all <details> solutions
      document.querySelectorAll(".exam-solution:not([open])").forEach(function(el) {
        el.setAttribute("open", "");
        prePrintState.solutions.push(el);
      });
      // Show all blanks
      document.querySelectorAll(".exam-blank[aria-pressed='false']").forEach(function(el) {
        el.setAttribute("aria-pressed", "true");
        prePrintState.blanks.push(el);
      });
      // Reveal all choice answers
      document.querySelectorAll(".exam-choices[data-has-answer='true'][data-revealed='false']").forEach(function(group) {
        group.querySelectorAll(".exam-choice-option").forEach(function(opt) {
          if (opt.getAttribute("data-answer") === "true") {
            opt.classList.add("is-correct");
            var input = opt.querySelector(".exam-choice-input");
            if (input) input.checked = true;
          }
        });
        group.setAttribute("data-revealed", "true");
        prePrintState.choices.push(group);
      });
    }

    // Add print footer
    printUrlFooter = document.createElement("div");
    printUrlFooter.className = "print-footer";
    printUrlFooter.style.display = "none";
    printUrlFooter.innerHTML =
      '本页面打印自 <a href="' + window.location.href + '">' + window.location.href + '</a><br>' +
      '来源：<a href="https://wiki.byrdocs.org">BYR Docs 维基真题</a><br>' +
      '除非另有声明，本文件内容采用 <a href="https://creativecommons.org/licenses/by-nc-sa/4.0/">CC BY-NC-SA 4.0</a> 授权。';
    document.querySelector(".wiki-content")?.appendChild(printUrlFooter);
  });
  window.addEventListener("afterprint", function() {
    // Remove temporary print nodes
    if (printUrlFooter) { printUrlFooter.remove(); printUrlFooter = null; }
    // Restore previous state
    if (!prePrintState) return;
    if (prePrintState.withAnswers) {
      if (prePrintState.wasHidden) {
        window.__examState?.toggleAll?.();
      }
      prePrintState.solutions.forEach(function(el) { el.removeAttribute("open"); });
      prePrintState.blanks.forEach(function(el) { el.setAttribute("aria-pressed", "false"); });
      prePrintState.choices.forEach(function(group) {
        group.querySelectorAll(".exam-choice-option").forEach(function(opt) {
          opt.classList.remove("is-correct");
          var input = opt.querySelector(".exam-choice-input");
          if (input) input.checked = false;
        });
        group.setAttribute("data-revealed", "false");
      });
    }
    prePrintState = null;
  });

  examPrint?.addEventListener("click", function() {
    openExamPrintDialog();
  });
  examPrintDialogCancel?.addEventListener("click", function() {
    closeExamPrintDialog();
  });
  examPrintDialogConfirm?.addEventListener("click", function() {
    var withAnswers = examPrintAnswers instanceof HTMLInputElement
      ? examPrintAnswers.checked
      : true;
    var withInfo = examPrintInfo instanceof HTMLInputElement
      ? examPrintInfo.checked
      : true;
    startExamPrint(withAnswers, withInfo);
  });
  examPrintDialog?.addEventListener("click", function(event) {
    if (event.target === examPrintDialog) closeExamPrintDialog();
  });
  // Ctrl/Cmd+P also opens options instead of printing immediately
  window.addEventListener("keydown", function(event) {
    if (!(event.ctrlKey || event.metaKey)) return;
    if (event.key !== "p" && event.key !== "P") return;
    if (!(examPrintDialog instanceof HTMLDialogElement)) return;
    event.preventDefault();
    openExamPrintDialog();
  });

  // Answers toggle
  var updateExamAnswersToggle = function() {
    if (!(examAnswersToggle instanceof HTMLButtonElement)) return;
    var hasRevealable = window.__examState?.hasRevealable?.() ?? false;
    var allShown = hasRevealable && (window.__examState?.getAllShown?.() ?? false);
    var label = allShown ? "隐藏全部答案" : "显示全部答案";
    var tooltip = hasRevealable ? label : "暂无可显示答案";
    examAnswersToggle.disabled = !hasRevealable;
    examAnswersToggle.dataset.state = allShown ? "shown" : "hidden";
    examAnswersToggle.dataset.tooltip = tooltip;
    examAnswersToggle.setAttribute("aria-label", label);
    examAnswersToggle.setAttribute("aria-pressed", "" + allShown);
  };
  updateExamAnswersToggle();
  window.addEventListener(
    window.__examState?.events?.change ?? "examstatechange",
    updateExamAnswersToggle,
  );
  examAnswersToggle?.addEventListener("click", function() {
    window.__examState?.toggleAll?.();
  });
  requestAnimationFrame(function() { window.__examState?.sync?.(); });
</script>
